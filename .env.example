# ─────────────────────────────────────────────────────────────
# KITS Placement Intelligence Hub — Environment Configuration
# ─────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://kits:password@localhost:5432/kits_placement

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long

# Groq AI (replaces Ollama for text generation)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# OpenRouter (one key, many models — used for research agents)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_2=nvidia/nemotron-nano-9b-v2:free

# Google Generative AI (Gemini — used for research agents)
# Get your key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Research pipeline configuration
# Comma-separated list of providers for the multi-LLM research fan-out
RESEARCH_PROVIDERS=openrouter,groq,gemini
LLM_TEMPERATURE=0.2

# Ollama (used only for embeddings)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Features
ENABLE_EMBEDDINGS=true
MAX_CONTEXT_LENGTH=2000
CHAT_SESSION_TTL=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
