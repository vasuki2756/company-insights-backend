  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [company_id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("student_targets")
}

model StudentFavorite {
  id        Int      @id @default(autoincrement())
  userId    String
  companyId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [company_id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("student_favorites")
}

model StudentPrepProgress {
  id           Int       @id @default(autoincrement())
  userId       String
  skillSetId   Int
  currentLevel Int
  gapHours     Decimal?
  updatedAt    DateTime  @updatedAt

  user  User             @relation(fields: [userId], references: [userId], onDelete: Cascade)
  skill skill_set_master @relation(fields: [skillSetId], references: [skill_set_id], onDelete: Cascade)

  @@unique([userId, skillSetId])
  @@index([userId])
  @@index([skillSetId])
  @@map("student_prep_progress")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model Embedding {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique
  embedding   Unsupported("vector(384)")?
  sectionType String?
  content     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [company_id], onDelete: Cascade)

  @@index([companyId])
  @@index([sectionType])
  @@map("embeddings")
}
