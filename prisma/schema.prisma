generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), pgvector(map: "vector", schema: "extensions")]
}

/// Top-level company information. Each row represents one company
/// that students can research and target for placements.
model Company {
  company_id                        Int                                 @id
  name                              String?
  shortName                         String?                             @map("short_name")
  category                          String?
  incorporationYear                 String?                             @map("incorporation_year")
  nature_of_company                 String?
  headquarters_address              String?
  office_count                      String?
  employeeSize                      String?                             @map("employee_size")
  websiteUrl                        String?                             @map("website_url")
  linkedin_url                      String?
  twitter_handle                    String?
  facebook_url                      String?
  instagram_url                     String?
  primary_contact_email             String?
  primary_phone_number              String?
  overview_text                     String?
  vision_statement                  String?
  mission_statement                 String?
  legal_issues                      String?
  carbon_footprint                  String?
  minCgpa                           Decimal? @map("min_cgpa")
  package                           String?
  selectionRate                     String? @map("selection_rate")
  applicationDeadline               DateTime? @map("application_deadline")
  driveDate                         DateTime? @map("drive_date")
  yoyGrowthRate                     String? @map("yoy_growth_rate")
  glassdoorRating                   Decimal? @map("glassdoor_rating")
  googleRating                      Decimal? @map("google_rating")
  companyType                       String? @map("company_type")
  employeeCount                     Int? @map("employee_count")
  headquarters                      String?
  createdAt                         DateTime? @default(now()) @map("created_at")
  company_brand_reputation          company_brand_reputation[]
  company_business                  company_business[]
  company_compensation              company_compensation[]
  company_core_values               company_core_values[]
  company_culture                   company_culture[]
  company_customer_testimonials     company_customer_testimonials[]
  company_esg_ratings               company_esg_ratings[]
  company_ethical_sourcing          company_ethical_sourcing[]
  company_financials                company_financials[]
  company_flexibility_level         company_flexibility_level[]
  company_geopolitical_risks        company_geopolitical_risks[]
  company_history                   company_history[]
  company_json                      company_json?
  company_skill_levels              company_skill_levels[]
  company_logistics                 company_logistics[]
  company_logo                      company_logo[]
  company_macro_risks               company_macro_risks[]
  company_marketing_videos          company_marketing_videos[]
  company_office_locations_map      company_office_locations_map[]
  company_operating_countries_map   company_operating_countries_map[]
  company_people                    company_people[]
  company_recent_news               company_recent_news[]
  company_regulatory_status         company_regulatory_status[]
  company_supply_chain_dependencies company_supply_chain_dependencies[]
  company_talent_growth             company_talent_growth[]
  company_technologies              company_technologies[]

  studentTargets   StudentTarget[]
  studentFavorites StudentFavorite[]
  embeddings       Embedding[]

  @@index([category], map: "idx_companies_category")
  @@index([name], map: "idx_companies_name")
  @@map("companies")
}

