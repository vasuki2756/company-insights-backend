  recruiter
  admin

  @@map("roles")
}

model User {
  userId       String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(student)
  profileData  Json?
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  studentSkills      StudentSkill[]
  studentTargets     StudentTarget[]
  studentFavorites   StudentFavorite[]
  studentPrepProgress StudentPrepProgress[]
  auditLogs          AuditLog[]

  @@index([email])
  @@map("users")
}

